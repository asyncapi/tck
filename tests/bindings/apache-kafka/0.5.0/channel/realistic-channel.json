{
  "topic": "my-specific-topic",
  "partitions": 20,
  "replicas": 3,
  "topicConfiguration": {
    "cleanup.policy": ["compact", "delete"],
    "retention.ms": 604800000,
    "retention.bytes": 104857600,
    "delete.retention.ms": 86400000,
    "max.message.bytes": 1048576,
    "confluent.key.schema.validation": true,
    "confluent.key.subject.name.strategy": "io.confluent.kafka.serializers.subject.TopicNameStrategy",
    "confluent.value.schema.validation": false,
    "confluent.value.subject.name.strategy": "io.confluent.kafka.serializers.subject.RecordNameStrategy"
  },
  "bindingVersion": "0.5.0"
} 