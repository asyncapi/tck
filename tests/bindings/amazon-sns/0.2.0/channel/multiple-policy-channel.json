{
  "name": "multi-policy-topic",
  "policy": {
    "statements": [
      {
        "effect": "Allow",
        "principal": {
          "AWS": "arn:aws:iam::123456789012:root"
        },
        "action": ["sns:Publish", "sns:Subscribe"],
        "resource": "arn:aws:sns:us-east-1:123456789012:multi-policy-topic"
      },
      {
        "effect": "Allow",
        "principal": {
          "Service": "events.amazonaws.com"
        },
        "action": "sns:Publish",
        "resource": "arn:aws:sns:us-east-1:123456789012:multi-policy-topic",
        "condition": {
          "ArnLike": {
            "aws:SourceArn": "arn:aws:events:us-east-1:123456789012:rule/*"
          }
        }
      },
      {
        "effect": "Deny",
        "principal": "*",
        "action": ["sns:DeleteTopic", "sns:RemovePermission"],
        "resource": "arn:aws:sns:us-east-1:123456789012:multi-policy-topic",
        "condition": {
          "StringNotEquals": {
            "aws:PrincipalTag/Role": "Administrator"
          }
        }
      }
    ]
  },
  "tags": {
    "environment": "staging",
    "security": "enhanced",
    "managed-by": "terraform"
  },
  "bindingVersion": "0.2.0"
}