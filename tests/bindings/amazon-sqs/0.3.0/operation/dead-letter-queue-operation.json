{
  "queues": [
    {
      "name": "payment-processing-queue",
      "fifoQueue": false,
      "visibilityTimeout": 30,
      "messageRetentionPeriod": 259200,
      "redrivePolicy": {
        "deadLetterQueue": {
          "arn": "arn:aws:sqs:us-east-1:123456789012:payment-failed-dlq"
        },
        "maxReceiveCount": 3
      },
      "tags": {
        "environment": "production",
        "application": "payment-processing",
        "criticality": "high"
      }
    },
    {
      "name": "payment-failed-dlq",
      "fifoQueue": false,
      "visibilityTimeout": 60,
      "messageRetentionPeriod": 1209600,
      "policy": {
        "statements": [
          {
            "effect": "Allow",
            "principal": {
              "AWS": "arn:aws:iam::123456789012:role/DLQProcessor"
            },
            "action": [
              "sqs:ReceiveMessage",
              "sqs:DeleteMessage",
              "sqs:GetQueueAttributes"
            ],
            "resource": "arn:aws:sqs:us-east-1:123456789012:payment-failed-dlq"
          },
          {
            "effect": "Allow",
            "principal": {
              "AWS": "arn:aws:iam::123456789012:role/DLQMonitor"
            },
            "action": [
              "sqs:GetQueueAttributes",
              "sqs:ListDeadLetterSourceQueues"
            ],
            "resource": "arn:aws:sqs:us-east-1:123456789012:payment-failed-dlq"
          }
        ]
      },
      "tags": {
        "environment": "production",
        "type": "dead-letter-queue",
        "retention": "14-days"
      }
    }
  ],
  "bindingVersion": "0.3.0"
}